{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg0": "#0f1c1e",
    "bg1": "#152528",
    "bg2": "#1d3337",
    "bg3": "#254147",
    "bg4": "#2d4f56",
    "fg0": "#eaeeee",
    "fg1": "#e6eaea",
    "fg2": "#cbd9d8",
    "fg3": "#587b7b",
    "sel0": "#293e40",
    "sel1": "#425e5e",
    "red": "#e85c51",
    "red_bright": "#eb746b",
    "red_dim": "#c54e45",
    "green": "#7aa4a1",
    "green_bright": "#8eb2af",
    "green_dim": "#688b89",
    "blue": "#5a93aa",
    "blue_bright": "#73a3b7",
    "blue_dim": "#4d7d90",
    "cyan": "#a1cdd8",
    "cyan_bright": "#afd4de",
    "cyan_dim": "#89aeb8",
    "magenta": "#ad5c7c",
    "magenta_bright": "#b97490",
    "magenta_dim": "#934e69",
    "orange": "#ff8349",
    "orange_bright": "#ff9664",
    "orange_dim": "#d96f3e",
    "yellow": "#fda47f",
    "yellow_bright": "#fdb292",
    "yellow_dim": "#d78b6c",
    "pink": "#cb7985",
    "pink_bright": "#d38d97",
    "comment": "#6d7f8b",
    "diff_add": "#1a3533",
    "diff_delete": "#2d2022"
  },
  "theme": {
    "primary": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "secondary": {
      "dark": "magenta",
      "light": "magenta_dim"
    },
    "accent": {
      "dark": "cyan",
      "light": "cyan_dim"
    },
    "error": {
      "dark": "red",
      "light": "red_dim"
    },
    "warning": {
      "dark": "orange",
      "light": "orange_dim"
    },
    "success": {
      "dark": "green",
      "light": "green_dim"
    },
    "info": {
      "dark": "blue_bright",
      "light": "blue"
    },
    "text": {
      "dark": "fg1",
      "light": "bg1"
    },
    "textMuted": {
      "dark": "fg2",
      "light": "bg3"
    },
    "background": {
      "dark": "bg1",
      "light": "fg0"
    },
    "backgroundPanel": {
      "dark": "bg0",
      "light": "fg1"
    },
    "backgroundElement": {
      "dark": "bg3",
      "light": "fg2"
    },
    "border": {
      "dark": "bg2",
      "light": "fg2"
    },
    "borderActive": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "borderSubtle": {
      "dark": "bg4",
      "light": "fg3"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green_dim"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red_dim"
    },
    "diffContext": {
      "dark": "fg2",
      "light": "bg3"
    },
    "diffHunkHeader": {
      "dark": "comment",
      "light": "comment"
    },
    "diffHighlightAdded": {
      "dark": "green_bright",
      "light": "green"
    },
    "diffHighlightRemoved": {
      "dark": "red_bright",
      "light": "red"
    },
    "diffAddedBg": {
      "dark": "diff_add",
      "light": "#e0f0ef"
    },
    "diffRemovedBg": {
      "dark": "diff_delete",
      "light": "#f0e0e0"
    },
    "diffContextBg": {
      "dark": "bg2",
      "light": "fg1"
    },
    "diffLineNumber": {
      "dark": "fg3",
      "light": "comment"
    },
    "diffAddedLineNumberBg": {
      "dark": "diff_add",
      "light": "#e0f0ef"
    },
    "diffRemovedLineNumberBg": {
      "dark": "diff_delete",
      "light": "#f0e0e0"
    },
    "markdownText": {
      "dark": "fg1",
      "light": "bg1"
    },
    "markdownHeading": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "markdownLinkText": {
      "dark": "cyan",
      "light": "cyan_dim"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green_dim"
    },
    "markdownBlockQuote": {
      "dark": "comment",
      "light": "comment"
    },
    "markdownEmph": {
      "dark": "yellow",
      "light": "yellow_dim"
    },
    "markdownStrong": {
      "dark": "orange",
      "light": "orange_dim"
    },
    "markdownHorizontalRule": {
      "dark": "fg3",
      "light": "fg2"
    },
    "markdownListItem": {
      "dark": "cyan_bright",
      "light": "cyan"
    },
    "markdownListEnumeration": {
      "dark": "orange",
      "light": "orange_dim"
    },
    "markdownImage": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "markdownImageText": {
      "dark": "cyan",
      "light": "cyan_dim"
    },
    "markdownCodeBlock": {
      "dark": "fg1",
      "light": "bg1"
    },
    "syntaxComment": {
      "dark": "comment",
      "light": "comment"
    },
    "syntaxKeyword": {
      "dark": "magenta",
      "light": "magenta_dim"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue_dim"
    },
    "syntaxVariable": {
      "dark": "fg1",
      "light": "bg1"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green_dim"
    },
    "syntaxNumber": {
      "dark": "orange",
      "light": "orange_dim"
    },
    "syntaxType": {
      "dark": "cyan",
      "light": "cyan_dim"
    },
    "syntaxOperator": {
      "dark": "blue_bright",
      "light": "blue"
    },
    "syntaxPunctuation": {
      "dark": "fg2",
      "light": "bg3"
    }
  }
